---
import Layout from '../../../layouts/Layout.astro'
import { getGroupEntries, generateGroupRoutes } from '../../../lib/cms/query';
import PinningScript from '../../../components/PinningScript.astro';
const root = 'note';

export async function getStaticPaths() {
  // For notes, the root param is 'note', and the group param is 'note'
  // (since the group name is used as the 'note' param)
  return await generateGroupRoutes('note', 'note', 'note');
}

const { note } = Astro.params;
const groupEntries = await getGroupEntries(root, note as string);
---

<Layout>
  <h1>{note}</h1>
  <div class="grid" id="fileGrid">
    {groupEntries.map((entry) => (
      <article class="card" data-file-id={entry.id}>
        <a class="card-link" href={`/notes/${note}/${entry.data.slug}`}>
          <h2>{entry.data.title}</h2>
          <p>{entry.data.description}</p>
        </a>
        <button class="pin-btn" data-file-id={entry.id}>❤️</button>
      </article>
    ))}
  </div>
</Layout>

<PinningScript />