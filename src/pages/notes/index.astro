---
import Layout from '../../layouts/Layout.astro';
import {
  getDomainEntries,
  getGroupsMap,
  filterByGroup,
  formatDate,
  formatTitle
} from '../../lib/cms/query';

const root = 'note';
const title = formatTitle(root);
const entries = await getDomainEntries(root);
const groups = getGroupsMap(entries)[root] ?? [];

const groupData = groups.map((group) => {
  const items = filterByGroup(entries, root, group);
  return {
    name: group,
    title: formatTitle(group),
    count: items.length,
    meta: formatDate(items) || '—',
    href: `/notes/${group}`
  };
});
---

<Layout>
  <h1>{title}</h1>
  <div class="grid">
    {groupData.map((group) => (
      <a class="card" href={group.href}>
        <h2>{group.title}</h2>
        <p>{group.count} notes</p>
        <span class="meta">{group.meta}</span>
      </a>
    ))}
  </div>
</Layout>