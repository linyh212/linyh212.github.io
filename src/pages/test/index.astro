---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { getGroupsByRoot, getGroupEntriesByRoot, getContentRoot, getRootGroupTitle, formatGroupMeta } from '../../lib/content'

const entries = await getCollection('content')
const groupsByRoot = getGroupsByRoot(entries)
const roots = Object.keys(groupsByRoot)
---

<Layout>
  <div class="container">
    {
      roots.map((root) => {
        const groups = groupsByRoot[root] || []
        return (
          <div class="root-section">
            <h1 style="margin-top:2rem">{getRootGroupTitle(root)}</h1>
            <div class="grid">
              {
                groups.map((group) => {
                  const items = getGroupEntriesByRoot(entries, root, group)
                  const categories = [...new Set(items.map(getContentRoot))].sort().join(', ')
                  const meta = formatGroupMeta(items)
                  const href = root === 'note' ? `/notes/${group}` : `/project/${group}`

                  return (
                  <a class="card" href={href}>
                    <h2>{group}</h2>
                    <p>{items.length} notes<br />{categories}</p>
                    <span class="meta">
                      {meta}
                    </span>
                  </a>
                  )
                })
              }
            </div>
          </div>
        )
      })
    }
  </div>
</Layout>

<style>
  .container {
    max-width: 920px;
    margin: 0 auto;
    font-size: 1.08rem;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1.25rem;
    color: white;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .card {
    display: block;

    padding: 18px;

    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;

    background: rgba(255, 255, 255, 0.03);

    text-decoration: none;

    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  h2 {
    margin: 0 0 12px 0;
    font-size: 1.25rem;
    color: white;
  }

  p {
    margin: 0 0 16px 0;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .meta {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.4);
  }
</style>
