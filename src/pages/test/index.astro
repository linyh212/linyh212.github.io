---
import Layout from '../../layouts/Layout.astro';
import {
  getDomainEntries,
  getGroupsMap,
  filterByGroup,
  formatDate,
  formatTitle
} from '../../lib/cms/query';

const root = 'test';
const title = formatTitle(root);
const entries = await getDomainEntries(root);
const groups = getGroupsMap(entries)[root] ?? [];

const groupData = groups.map((group) => {
  const items = filterByGroup(entries, root, group);
  return {
    name: group,
    title: formatTitle(group),
    count: items.length,
    meta: formatDate(items) || '—',
    href: `/tests/${group}`
  };
});
---

<Layout>
  <div class="container">
    <h1>{title}</h1>
    <div class="grid">
      {groupData.map((group) => (
        <a class="card" href={group.href}>
          <h2>{group.title}</h2>
          <p>{group.count} tests</p>
          <span class="meta">{group.meta}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>