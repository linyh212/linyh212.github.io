---
import Layout from '../../layouts/Layout.astro';
import {
  getDomainEntries,
  getGroupsByRoot,
  getGroupEntriesByRoot,
  formatGroupMeta,
  getRootGroupTitle
} from '../../lib/cms/domain';

const root = 'test';
const title = getRootGroupTitle(root);

const entries = await getDomainEntries(root);

const groups = getGroupsByRoot(entries)[root] ?? [];

const groupData = groups.map((group) => {
  const items = getGroupEntriesByRoot(entries, root, group);

  return {
    name: group,
    count: items.length,
    meta: formatGroupMeta(items) || '—',
    href: `/test/${group}`
  };
});
---

<Layout>
  <div class="container">
    <h1>{title}</h1>

    <div class="grid">
      {groupData.map((group) => (
        <a class="card" href={group.href}>
          <h2>{group.name}</h2>
          <p>{group.count} items</p>
          <span class="meta">{group.meta}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>