---
import Layout from '../../../layouts/Layout.astro'
import { getGroupEntries } from '../../../lib/cms/domain';
import { generateGroupRoutes } from '../../../lib/cms/routes';

import PinningScript from '../../../components/PinningScript.astro';
const root = 'test';

export async function getStaticPaths() {
  // For test, the root param is 'test', and the group param is 'test'
  // (since the group name is used as the 'test' param)
  return await generateGroupRoutes('test', 'test', 'test');
}

const { test } = Astro.params;

const groupEntries = await getGroupEntries(root, test);
---

<Layout>
  <div class="container">
    <h1>{test}</h1>

    <div class="grid" id="fileGrid">
      {groupEntries.map((entry) => (
        <article class="card" data-file-id={entry.id}>
          <a class="card-link" href={`/test/${test}/${entry.data.slug}`}>
            <h2>{entry.data.title}</h2>
            <p>{entry.data.description}</p>
          </a>

          <button class="pin-btn" data-file-id={entry.id}>❤️</button>
        </article>
      ))}
    </div>
  </div>
</Layout>

<PinningScript />