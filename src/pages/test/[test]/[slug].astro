---
import { render } from 'astro:content';
import NoteLayout from '../../../layouts/NoteLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getMeta } from '../../../lib/cms/core';
import { getGroupEntries } from '../../../lib/cms/domain';
import { generateSlugRoutes } from '../../../lib/cms/routes';

export async function getStaticPaths() {
  return await generateSlugRoutes('test', 'test');
}

const { entry } = Astro.props;
const meta = getMeta(entry);
const testEntries = await getGroupEntries('test', meta.group);
const { Content } = await render(entry);
---

<NoteLayout
  projects={testEntries}
  currentSlug={meta.slug}
>
  <Fragment slot="sidebar">
    <Sidebar
      root="test"
      group={meta.group}
      projects={testEntries}
      currentSlug={meta.slug}
    />
  </Fragment>

  <h1>{entry.data.title}</h1>
  <Content />
</NoteLayout>