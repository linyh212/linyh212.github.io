---
import { getCollection, render } from 'astro:content';

import NoteLayout from '../../../layouts/NoteLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getGroupName } from '../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('content');

  return entries.map((entry: any) => ({
    params: {
      test: getGroupName(entry),
      slug: entry.data.slug
    },
    props: {
      test: getGroupName(entry),
      entry
    }
  }));
}

const { test, entry }: any = Astro.props;

const entries: any[] = await getCollection('content');
const testEntries = entries.filter((item: any) => getGroupName(item) === test);

const { Content } = await render(entry);
---

<NoteLayout
  projects={testEntries}
  currentSlug={entry.data.slug}
>
  <Fragment slot="sidebar">
    <Sidebar
      project={test}
      projects={testEntries}
      currentSlug={entry.data.slug}
    />
  </Fragment>

  <h1>{entry.data.title}</h1>

  <Content />
</NoteLayout>
