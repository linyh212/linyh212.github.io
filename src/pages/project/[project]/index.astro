---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("project");
  const getProjectName = (entry) => entry.id.split("/")[0];
  const projectNames = [...new Set(entries.map(getProjectName))];

  return projectNames.map((project) => ({
    params: { project },
    props: {
      project,
      entries: entries.filter((entry) => getProjectName(entry) === project),
    },
  }));
}

const { project, entries } = Astro.props;
---

<Layout>
  <div class="container">
    <h1>{project}</h1>

    <div class="grid">
      {
        entries.map((entry) => (
          <a class="card" href={`/project/${project}/${entry.data.slug}`}>
            <h2>{entry.data.title}</h2>
            <p>{entry.data.description}</p>

            <span class="meta">
              {entry.data.date.toLocaleDateString("zh-TW")}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  h1 {
    font-size: 28px;
    margin-bottom: 20px;
    color: white;
    text-transform: capitalize;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .card {
    display: block;

    padding: 16px;

    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;

    background: rgba(255, 255, 255, 0.03);

    text-decoration: none;

    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  h2 {
    margin: 0 0 8px 0;
    font-size: 18px;
    color: white;
  }

  p {
    margin: 0 0 12px 0;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
  }

  .meta {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
  }
</style>
