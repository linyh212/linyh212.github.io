---
import { getCollection, render } from 'astro:content';

import NoteLayout from '../../../layouts/NoteLayout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getGroupName } from '../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('content');

  return entries.map((entry: any) => ({
    params: {
      project: getGroupName(entry),
      slug: entry.data.slug
    },
    props: {
      project: getGroupName(entry),
      entry
    }
  }));
}

const { project, entry }: any = Astro.props;

const entries: any[] = await getCollection('content');
const projectEntries = entries.filter((item: any) => getGroupName(item) === project);

const { Content } = await render(entry);
---

<NoteLayout
  projects={projectEntries}
  currentSlug={entry.data.slug}
>
  <Fragment slot="sidebar">
    <Sidebar
      project={project}
      projects={projectEntries}
      currentSlug={entry.data.slug}
    />
  </Fragment>

  <h1>{entry.data.title}</h1>

  <Content />
</NoteLayout>
