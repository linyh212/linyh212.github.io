---
import { render } from "astro:content";
import NoteLayout from "../../../../layouts/NoteLayout.astro";
import Sidebar from "../../../../components/Sidebar.astro";
import { getMeta } from "../../../../lib/cms/core";
import { getGroupEntries } from "../../../../lib/cms/domain";
import { generateAllSlugRoutes } from "../../../../lib/cms/routes";

const { root, group, slug } = Astro.params;

export async function getStaticPaths() {
  return await generateAllSlugRoutes('root', 'group');
}

const { entry } = Astro.props;
const meta = getMeta(entry);
const projectEntries = await getGroupEntries(root, meta.group);
const { Content } = await render(entry);
---

<NoteLayout projects={projectEntries} currentSlug={meta.slug ?? slug}>
  <Fragment slot="sidebar">
    <Sidebar
      root={root}
      group={group}
      currentSlug={meta.slug ?? slug}
      projects={projectEntries}
    />
  </Fragment>

  <article class="content">
    <h1>{entry.data.title}</h1>
    <Content />
  </article>
</NoteLayout>

<style>
  .content {
    max-width: 920px;
    margin: 0 auto;
    font-size: 1.08rem;
    line-height: 1.85;
    color: #e5e7eb;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: white;
  }
</style>