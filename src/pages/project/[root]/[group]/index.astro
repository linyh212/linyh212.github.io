---
import Layout from '../../../../layouts/Layout.astro';
import Sidebar from '../../../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { getContentRoot, getGroupEntriesByRoot, formatGroupMeta, getRootGroupTitle } from '../../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('content');
  const groups = new Map();

  entries.forEach((entry: any) => {
    const root = getContentRoot(entry);
    const group = String(entry.id).split('/')[1] ?? '';

    if (group) {
      groups.set(`${root}/${group}`, { root, group });
    }
  });

  return Array.from(groups.values()).map((item) => ({ params: item }));
}

const { root, group } = Astro.params;
const entries = await getCollection('content');
const groupEntries = getGroupEntriesByRoot(entries, root, group);
const title = getRootGroupTitle(root);
---

<Layout>
  <div slot="sidebar">
    <Sidebar root={root} projects={groupEntries} group={group} />
  </div>

  <div class="container">
    <h1>{title}: {group}</h1>

    {groupEntries.length === 0 ? (
      <p>目前沒有此群組的內容。</p>
    ) : (
      <div class="grid">
        {groupEntries.map((entry) => (
          <a class="card" href={`/project/${root}/${group}/${entry.data.slug}`}>
            <h2>{entry.data.title}</h2>
            <p>{entry.data.description}</p>
            <span class="meta">{formatGroupMeta([entry])}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  .container {
    max-width: 920px;
    margin: 0 auto;
    font-size: 1.08rem;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1.25rem;
    color: white;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .card {
    display: block;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    text-decoration: none;
    transition: 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  h2 {
    margin: 0 0 12px 0;
    font-size: 1.25rem;
    color: white;
  }

  p {
    margin: 0 0 16px 0;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .meta {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.4);
  }
</style>
