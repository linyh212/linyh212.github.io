---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { buildProjectTree } from "../../../lib/cms/tree";

export async function getStaticPaths() {
  const allEntries = await getCollection("content");
  const projectTree = buildProjectTree(allEntries);

  return projectTree.map((section) => ({
    params: { root: section.root },
    props: { section },
  }));
}

const { root } = Astro.params;

const { section } = Astro.props;
---

<Layout>
  <div class="container">
    <h1>{section?.title ?? root}</h1>

    <div class="cms-grid">
      {section?.groups.map((group) => (
        <a class="cms-card" href={group.href}>
          <h2>{group.name}</h2>
          <p>{group.count} items</p>
          <span class="cms-meta">{group.meta}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>