---
import Layout from "../../../layouts/Layout.astro";
import { getEntries, buildProjectTree } from "../../../lib/cms/query";

export async function getStaticPaths() {
  const allEntries = await getEntries();
  const projectTree = buildProjectTree(allEntries);

  return projectTree.map((section) => ({
    params: { root: section.root },
    props: { section },
  }));
}

const { root } = Astro.params;
const { section } = Astro.props;
---

<Layout>
  <h1>{section?.title ?? root}</h1>
  <div class="cms-grid">
    {section?.groups.map((group) => (
      <a class="cms-card" href={group.href}>
        <h2>{group.title}</h2>
        <p>{group.count} items</p>
      </a>
    ))}
  </div>
</Layout>