---
import Navbar from '../components/Navbar.astro';
import 'katex/dist/katex.min.css';

const { projects, currentSlug } = Astro.props;
---

<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>My Astro Site</title>
  </head>

  <body>
    <Navbar />

    <div class="overlay"></div>

    <div class="container">
      <slot name="sidebar" />

      <main>
        <article class="markdown">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style>
/* =========================
   GLOBAL
========================= */
:global(body) {
  margin: 0;
  background: rgb(30, 30, 30);
  color: #e5e7eb;
  font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

/* =========================
   LAYOUT
========================= */
.container {
  display: flex;
  min-height: calc(100vh - 70px);
}

main {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 48px 24px;
}

.markdown {
  width: 100%;
  max-width: 920px;
  font-size: 1.08rem;
  line-height: 1.85;
}

.markdown :global(.katex-display) {
  overflow-x: auto;
  overflow-y: hidden;
  padding: 0.25rem 0;
}

/* =========================
   HEADINGS
========================= */
.markdown :global(h1) {
  font-size: 2.4rem;
  margin-bottom: 2rem;
  color: white;
}

.markdown :global(h2) {
  font-size: 1.8rem;
  margin-top: 3rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid #374151;
  color: white;
}

.markdown :global(h3) {
  font-size: 1.3rem;
  margin-top: 2rem;
  color: white;
}

/* =========================
   TEXT
========================= */
.markdown :global(p) {
  margin: 1rem 0;
  color: #d1d5db;
  text-align: justify;
  text-justify: inter-ideograph;
}

.markdown :global(ul),
.markdown :global(ol) {
  padding-left: 1.5rem;
}

.markdown :global(li) {
  margin: 0.4rem 0;
  text-align: justify;
  text-justify: inter-ideograph;
}

.markdown :global(h1),
.markdown :global(h2),
.markdown :global(h3),
.markdown :global(pre),
.markdown :global(table),
.markdown :global(.katex-display) {
  text-align: left;
}

/* =========================
   LINKS
========================= */
.markdown :global(a) {
  color: #60a5fa;
  text-decoration: none;
}

.markdown :global(a:hover) {
  text-decoration: underline;
}

/* =========================
   INLINE CODE
========================= */
.markdown :global(p code),
.markdown :global(li code) {
  background: #1f2937;
  padding: 2px 6px;
  border-radius: 6px;
  color: #93c5fd;
  font-size: 0.95em;
}

.markdown :global(pre) {
  background: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  padding: 1rem;
  overflow-x: auto;
  margin: 1.5rem 0;
  font-size: 0.98rem;
}

.markdown :global(pre code) {
  background: transparent;
  padding: 0;
}

/* =========================
   BLOCKQUOTE
========================= */
.markdown :global(blockquote) {
  margin: 1.5rem 0;
  padding: 1rem;
  border-left: 4px solid #3b82f6;
  background: #1f2937;
  color: #cbd5e1;
  border-radius: 0 8px 8px 0;
}

/* =========================
   TABLE
========================= */
.markdown :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: 2rem 0;
}

.markdown :global(th),
.markdown :global(td) {
  border: 1px solid #374151;
  padding: 0.75rem;
}

.markdown :global(th) {
  background: #1f2937;
}

/* =========================
   IMAGE
========================= */
.markdown :global(img) {
  max-width: 100%;
  border-radius: 12px;
  margin: 2rem auto;
  display: block;
}

/* =========================
   HR
========================= */
.markdown :global(hr) {
  border: none;
  border-top: 1px solid #374151;
  margin: 3rem 0;
}

/* =========================
   MOBILE IMPROVEMENT
   HackMD / Notion feel
========================= */

@media (max-width: 768px) {

  .container {
    flex-direction: column;
  }

  slot[name="sidebar"] {
    display: flex;
    overflow-x: auto;
    white-space: nowrap;

    border-bottom: 1px solid #2a2a2a;
  }

  main {
    padding: 20px 16px;
    justify-content: flex-start;
  }

  .markdown {
    max-width: 100%;
    font-size: 1rem;
    line-height: 1.8;
  }

  .markdown :global(h1) {
    font-size: 1.8rem;
  }

  .markdown :global(h2) {
    font-size: 1.4rem;
  }

  .markdown :global(h3) {
    font-size: 1.2rem;
  }

  .markdown :global(pre) {
    padding: 0.8rem;
    font-size: 0.92rem;
  }

  .markdown :global(a) {
    padding: 2px 0;
  }
}
</style>

<style>
.overlay {
  display: none;
}

@media (max-width: 768px) {
  .overlay {
    display: block;
    position: fixed;
    inset: 0;

    background: rgba(0, 0, 0, 0.5);

    opacity: 0;
    pointer-events: none;

    transition: 0.25s ease;

    z-index: 1000;
  }

  .overlay.show {
    opacity: 1;
    pointer-events: auto;
  }
}
</style>
