---
import Navbar from "../components/Navbar.astro";
import "katex/dist/katex.min.css";
import "../lib/cms/style.css";
const { projects, currentSlug } = Astro.props;
---

<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>My Notes</title>
  </head>

  <body>
    <Navbar />

    <!-- mobile menu -->
    <div class="mobile-menu">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/project">Project</a>
    </div>

    <!-- overlay -->
    <div class="overlay"></div>

    <div class="container">
      <slot name="sidebar" />

      <main>
        <article class="markdown">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style>
  :root {
    --navbar-height: 60px;
  }

/* =========================
  BASE
========================= */
  :global(body) {
    margin: 0;
    background: #1e1e1e;
    color: #e5e7eb;
    font-family:
      Inter,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

/* =========================
  LAYOUT
========================= */
  .container {
    display: flex;
    min-height: 100vh;
  }

  main {
    flex: 1;
    display: flex;
    justify-content: center;
    padding: 24px;
    padding-top: calc(var(--navbar-height) + 24px);
    margin-left: 240px;
  }

  @media (max-width: 768px), (orientation: portrait) and (max-width: 1024px) {
    main {
      margin-left: 0;
    }
  }

  .markdown {
    max-width: 920px;
    width: 100%;
    font-size: 1.08rem;
    line-height: 1.85;
  }

  /* markdown alignment */
  .markdown :global(p),
  .markdown :global(li) {
    text-align: justify;
    text-justify: inter-ideograph;
  }

  .markdown :global(h1),
  .markdown :global(h2),
  .markdown :global(h3),
  .markdown :global(pre),
  .markdown :global(table),
  .markdown :global(.katex-display) {
    text-align: left;
  }

  .markdown :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
  }

/* =========================
  MOBILE MENU
========================= */
  :global(#hamburger-menu) {
    display: none;
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 768px), (orientation: portrait) and (max-width: 1024px) {
    :global(#hamburger-menu) {
      display: flex;
    }

    .mobile-menu {
      display: flex;
      flex-direction: column;
      gap: 12px;

      position: fixed;
      top: var(--navbar-height);
      left: 0;
      width: 100%;

      background: #0f0f0f;
      padding: 16px 24px;

      opacity: 0;
      transform: translateY(-10px);
      pointer-events: none;

      transition: 0.2s ease;

      z-index: 1002;
    }

    .mobile-menu.show {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .mobile-menu a {
      color: #aaa;
      text-decoration: none;
      font-size: 14px;
    }

    .mobile-menu a:hover {
      color: white;
    }
  }

/* =========================
  OVERLAY
========================= */
  .overlay {
    display: none;
  }

  @media (max-width: 768px), (orientation: portrait) and (max-width: 1024px) {
    .overlay {
      display: block;
      position: fixed;
      inset: 0;

      background: rgba(0, 0, 0, 0.5);

      opacity: 0;
      pointer-events: none;

      transition: 0.25s ease;

      z-index: 1000;
    }

    .overlay.show {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>
