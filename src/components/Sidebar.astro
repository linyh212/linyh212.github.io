---
const { root: rootName, projects, currentSlug, group } = Astro.props;
---

<aside class="sidebar">
  <a class="project-link" href="/project">Back to Project</a>

  <h2>
    {rootName ? rootName.charAt(0).toUpperCase() + rootName.slice(1) : "Items"}
  </h2>

  {
    projects.map((project) => (
      <a
        href={
          group
            ? `/project/${rootName}/${group}/${project.data.slug}`
            : `/project/${rootName}/${project.data.slug}`
        }
        class={project.data.slug === currentSlug ? "active" : ""}
      >
        {project.data.title}
      </a>
    ))
  }
</aside>

<style>
.sidebar {
  position: fixed;
  top: var(--navbar-height);
  left: 0;

  width: 240px;
  height: calc(100vh - var(--navbar-height));

  padding: 20px 16px;
  box-sizing: border-box;

  overflow-y: auto;

  background: #0f0f0f;
  border-right: 1px solid rgba(255, 255, 255, 0.06);

  display: flex;
  flex-direction: column;
  gap: 6px;

  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.15) transparent;

  z-index: 999;

  transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
              opacity 0.2s ease;

  will-change: transform;
}

.sidebar::-webkit-scrollbar {
  width: 6px;
}
.sidebar::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 999px;
}

.sidebar h2 {
  color: rgba(255, 255, 255, 0.7);
  font-size: 12px;
  letter-spacing: 0.5px;
  margin: 6px 8px 10px;
}

/* links */
.sidebar a {
  position: relative;

  color: rgba(255, 255, 255, 0.65);
  text-decoration: none;

  padding: 10px 12px;
  border-radius: 10px;

  transition: background 0.2s ease, color 0.2s ease;
}

.sidebar a:hover {
  background: rgba(255, 255, 255, 0.06);
  color: white;
}

.sidebar a.active {
  color: white;
  background: rgba(255, 255, 255, 0.06);
}

.sidebar a.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 3px;
  border-radius: 999px;
  background: white;
}

.sidebar .project-link {
  color: white;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.06);
}

/* =========================
   MOBILE
========================= */
@media (max-width: 768px), (orientation: portrait) and (max-width: 1024px) {
  .sidebar {
    width: 260px;

    transform: translate3d(-100%, 0, 0);
    opacity: 0;

    pointer-events: none;

    z-index: 1001;

    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.18s ease;

    backdrop-filter: blur(10px);
    background: rgba(15, 15, 15, 0.95);
  }

  .sidebar.open {
    transform: translate3d(0, 0, 0);
    opacity: 1;

    pointer-events: auto;
  }
}
</style>