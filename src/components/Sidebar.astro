---
const { root: rootName, projects, currentSlug, group } = Astro.props;
---

<aside class="sidebar">
  <a class="project-link" href="/project">Back to Project</a>

  <h2>
    {rootName ? rootName.charAt(0).toUpperCase() + rootName.slice(1) : "Items"}
  </h2>

  {
    projects.map((project) => (
      <a
        href={
          group
            ? `/project/${rootName}/${group}/${project.data.slug}`
            : `/project/${rootName}/${project.data.slug}`
        }
        class={project.data.slug === currentSlug ? "active" : ""}
      >
        {project.data.title}
      </a>
    ))
  }
</aside>

<style>
.sidebar {
  position: sticky;
  top: var(--navbar-height);
  flex-shrink: 0;
  width: var(--sidebar-width);
  height: calc(100vh - var(--navbar-height));
  padding: 20px 16px;
  box-sizing: border-box;
  overflow-y: auto;
  background: var(--color-bg-surface);
  border-right: 1px solid var(--border-main);
  display: flex;
  flex-direction: column;
  gap: 6px;
  z-index: 999;
}

.sidebar h2 {
  color: var(--text-soft);
  font-size: 12px;
  letter-spacing: 0.5px;
  margin: 6px 8px 10px;
}

.sidebar a {
  color: var(--text-normal);
  text-decoration: none;
  padding: 10px 12px;
  border-radius: 10px;
  transition: background var(--transition-speed) var(--ease-in-out), color var(--transition-speed) var(--ease-in-out);
}

.sidebar a:hover {
  background: var(--color-bg-card-hover);
  color: var(--text-main); 
}

.sidebar a.active {
  position: relative;
  color: var(--text-main);
  background: var(--color-bg-card-hover);
}

.sidebar a.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 3px;
  border-radius: 999px;
  background: var(--color-accent);
  transition: height var(--transition-speed) var(--ease-out);
}

.sidebar .project-link {
  color: var(--text-main);
  font-weight: 600;
  background: var(--color-bg-card-hover);
}

/* Mobile */
@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    top: var(--navbar-height);
    left: 0;
    width: 260px;
    height: calc(100vh - var(--navbar-height));
    transform: translate3d(-100%, 0, 0);
    opacity: 0;
    pointer-events: none;
    z-index: 1001;
    transition: transform 0.3s var(--ease-out), opacity 0.2s ease;
    backdrop-filter: blur(10px);
    background: var(--color-bg-surface);
  }

  .sidebar.open {
    transform: translate3d(0, 0, 0);
    opacity: 1;
    pointer-events: auto;
  }
}
</style>