---
const { project: projectName, projects, currentSlug } = Astro.props;
---

<aside class="sidebar">
  <a class="project-link" href={`/project/${projectName}`}>Back to Project</a>
  <h2>Notes</h2>

  {
    projects.map((project) => (
      <a
        href={`/project/${projectName}/${project.data.slug}`}
        class={project.data.slug === currentSlug ? 'active' : ''}
      >
        {project.data.title}
      </a>
    ))
  }
</aside>

<style>
.sidebar {
  width: 240px;
  padding: 24px;
  background: #0f0f0f;
  border-right: 1px solid #222;

  display: flex;
  flex-direction: column;
  gap: 8px;
}

.sidebar h2 {
  color: white;
  font-size: 14px;
  opacity: 0.8;
  margin-bottom: 12px;
}

.sidebar a {
  color: #aaa;
  text-decoration: none;
  padding: 8px 12px;
  border-radius: 8px;
  transition: 0.2s;
}

.sidebar .project-link {
  color: white;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.06);
}

.sidebar a:hover {
  background: #333;
  color: white;
}

.active {
  background: #333;
  color: white !important;
}

/* =========================
   MOBILE DRAWER
========================= */
@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;

    height: 100vh;
    width: 260px;

    transform: translateX(-100%);
    transition: transform 0.25s ease;

    z-index: 1001;
  }

  .sidebar.open {
    transform: translateX(0);
  }
}
</style>
