---
// Astro 前言區塊
---

<ribbon-cursor {...Astro.props}></ribbon-cursor>

<style>
  ribbon-cursor {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 9999;
  }
</style>

<script>
interface RibbonConfig {
  colors: string[];
  spring: number;
  friction: number;
  thickness: number;
  offset: number;
  maxAge: number;
  pointCount: number;
  speed: number;
  fade: boolean;
  shader: boolean;
  amplitude: number;
  bg: [number, number, number, number];
}

class RibbonCursor extends HTMLElement {
  private config!: RibbonConfig;
  private canvas!: HTMLCanvasElement;
  private ctx!: CanvasRenderingContext2D;
  private width = 0;
  private height = 0;
  private dpr = 1;
  private mouse = { x: 0.5, y: 0.5 };
  private ribbons: any[] = [];
  private frameId: number | null = null;
  private lastTime = performance.now();
  private resizeObserver!: ResizeObserver;
  private intersectionObserver!: IntersectionObserver;
  private isVisible = false;
  private isAnimating = false;
  private mouseMoved = false;
  private time = 0;
  private boundHandleMove: (e: MouseEvent | TouchEvent) => void;
  private _isMobile = false;

  constructor() {
    super();
    this.boundHandleMove = this.handleMove.bind(this);
  }

  connectedCallback() {
    this._isMobile = window.matchMedia('(pointer: coarse)').matches;
    if (this._isMobile) return;

    this.config = this.parseConfig();
    this.canvas = document.createElement('canvas');
    this.canvas.style.cssText = 'display:block;width:100%;height:100%;';
    this.appendChild(this.canvas);
    this.ctx = this.canvas.getContext('2d')!;

    this.initRibbons();
    this.initObservers();
    this.initEvents();
    this.resize();
  }

  disconnectedCallback() {
    this.destroy();
  }

  private parseConfig(): RibbonConfig {
    const d = this.dataset;
    return {
      colors: JSON.parse(d.colors || '["#d6c37a"]'),
      spring: parseFloat(d.spring || "0.03"),
      friction: parseFloat(d.friction || "0.8"),
      thickness: parseFloat(d.thickness || "30"),
      offset: parseFloat(d.offset || "0.05"),
      maxAge: parseFloat(d.maxAge || "350"),
      pointCount: parseInt(d.pointCount || "50", 10),
      speed: parseFloat(d.speed || "0.5"),
      fade: !!d.fade,
      shader: !!d.shader,
      amplitude: parseFloat(d.amplitude || "2"),
      bg: JSON.parse(d.bg || "[0,0,0,0]"),
    };
  }

  private initRibbons() {
    const { colors, spring: bS, friction: bF, thickness: bT, offset, pointCount } = this.config;
    this.ribbons = [colors[0]].map((hex: string) => {
      const pts = Array.from({ length: pointCount }, () => ({ x: 0, y: 0 }));
      return {
        color: hex,
        spring: bS,
        friction: bF,
        thickness: Math.max(1, bT + (Math.random() - 0.5) * 3),
        offsetX: 0,
        offsetY: 0,
        velX: 0,
        velY: 0,
        points: pts,
      };
    });
  }

  private initObservers() {
    this.resizeObserver = new ResizeObserver(() => this.resize());
    this.resizeObserver.observe(this);

    this.intersectionObserver = new IntersectionObserver((entries) => {
      this.isVisible = entries[0].isIntersecting;
      if (this.isVisible && !this.isAnimating) this.startAnimation();
    });
    this.intersectionObserver.observe(this);
  }

  private initEvents() {
    if (this._isMobile) return;
    window.addEventListener('mousemove', this.boundHandleMove);
    window.addEventListener('touchmove', this.boundHandleMove, { passive: true });
    window.addEventListener('touchstart', this.boundHandleMove, { passive: true });
  }

  private resize() {
    const rect = this.getBoundingClientRect();
    this.width = rect.width;
    this.height = rect.height;
    this.dpr = Math.min(window.devicePixelRatio || 1, 2);
    this.canvas.width = this.width * this.dpr;
    this.canvas.height = this.height * this.dpr;
    this.canvas.style.width = this.width + 'px';
    this.canvas.style.height = this.height + 'px';
    this.ctx.scale(this.dpr, this.dpr);
  }

  private handleMove(e: MouseEvent | TouchEvent) {
    if (this._isMobile) return;
    const rect = this.getBoundingClientRect();
    let cx, cy;
    if ('changedTouches' in e) {
      cx = e.changedTouches[0].clientX;
      cy = e.changedTouches[0].clientY;
    } else {
      cx = (e as MouseEvent).clientX;
      cy = (e as MouseEvent).clientY;
    }
    this.mouse.x = (cx - rect.left) / (rect.width || 1);
    this.mouse.y = 1 - (cy - rect.top) / (rect.height || 1);
    this.mouseMoved = true;
    if (this.isVisible && !this.isAnimating) this.startAnimation();
  }

  private startAnimation() {
    if (this._isMobile || this.isAnimating) return;
    this.isAnimating = true;
    this.lastTime = performance.now();
    this.renderLoop();
  }

  private renderLoop = () => {
    if (this._isMobile || !this.isVisible) {
      this.isAnimating = false;
      return;
    }

    const now = performance.now();
    const dt = Math.min(now - this.lastTime, 32);
    this.lastTime = now;
    this.time += dt * 0.002;

    const { speed, maxAge, fade, shader, amplitude, bg } = this.config;
    const targetX = this.mouse.x * 2 - 1;
    const targetY = this.mouse.y * 2 - 1;

    this.ctx.clearRect(0, 0, this.width, this.height);
    if (bg[3] > 0) {
      this.ctx.fillStyle = `rgba(${bg[0]*255},${bg[1]*255},${bg[2]*255},${bg[3]})`;
      this.ctx.fillRect(0, 0, this.width, this.height);
    }

    let moved = this.mouseMoved;
    this.mouseMoved = false;

    for (let r = 0; r < this.ribbons.length; r++) {
      const ribbon = this.ribbons[r];
      const noiseX = 0;
      const noiseY = 0;

      const pts = ribbon.points;
      const dx = targetX + ribbon.offsetX + noiseX - pts[0].x;
      const dy = targetY + ribbon.offsetY + noiseY - pts[0].y;
      ribbon.velX += dx * ribbon.spring;
      ribbon.velY += dy * ribbon.spring;
      ribbon.velX *= ribbon.friction;
      ribbon.velY *= ribbon.friction;
      pts[0].x += ribbon.velX;
      pts[0].y += ribbon.velY;

      const segDelay = maxAge / (pts.length - 1);
      const alpha = Math.min(1, (dt * speed) / segDelay);
      for (let i = 1; i < pts.length; i++) {
        const px = pts[i-1].x - pts[i].x;
        const py = pts[i-1].y - pts[i].y;
        if (Math.abs(px) > 1e-6 || Math.abs(py) > 1e-6) {
          pts[i].x += px * alpha;
          pts[i].y += py * alpha;
          moved = true;
        }
      }

      this.ctx.save();
      this.ctx.globalCompositeOperation = 'source-over';
      this.ctx.lineCap = 'round';
      this.ctx.lineJoin = 'round';

      for (let i = 1; i < pts.length; i++) {
        const p1 = pts[i - 1];
        const p2 = pts[i];
        
        const ratio = 1 - (i / pts.length);
        const currentWidth = ribbon.thickness * ratio * (this.height / 1000);
        
        const opacity = fade ? ratio : 1;
        this.ctx.strokeStyle = ribbon.color;
        this.ctx.globalAlpha = opacity;
        this.ctx.lineWidth = currentWidth;

        this.ctx.beginPath();
        this.ctx.moveTo(
          (p1.x * 0.5 + 0.5) * this.width,
          (p1.y * -0.5 + 0.5) * this.height
        );
        this.ctx.lineTo(
          (p2.x * 0.5 + 0.5) * this.width,
          (p2.y * -0.5 + 0.5) * this.height
        );
        this.ctx.stroke();
      }
      this.ctx.restore();
    }

    if (!moved) {
      this.isAnimating = false;
      return;
    }

    this.frameId = requestAnimationFrame(this.renderLoop);
  };

  public destroy() {
    if (!this.canvas) return;

    if (this.frameId) cancelAnimationFrame(this.frameId);
    window.removeEventListener('mousemove', this.boundHandleMove);
    window.removeEventListener('touchmove', this.boundHandleMove);
    window.removeEventListener('touchstart', this.boundHandleMove);
    this.resizeObserver?.disconnect();
    this.intersectionObserver?.disconnect();
    if (this.canvas.parentNode) this.canvas.parentNode.removeChild(this.canvas);
    this.isAnimating = false;
    this.isVisible = false;
    this.frameId = null;
    this.ribbons = [];
  }
}

if (!customElements.get('ribbon-cursor')) {
  customElements.define('ribbon-cursor', RibbonCursor);
}
</script>